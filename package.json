{
  "name": "@hanzo/zip",
  "version": "0.1.0",
  "description": "TypeScript SDK for HIP-0105 in-process extensions — write typed handlers, compile to goja-loadable JS.",
  "license": "BSD-3-Clause",
  "author": "Hanzo AI Inc.",
  "homepage": "https://github.com/hanzoai/zip-js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hanzoai/zip-js.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runtime/goja": {
      "types": "./dist/runtime/goja.d.ts",
      "import": "./dist/runtime/goja.js"
    },
    "./runtime/javy": {
      "types": "./dist/runtime/javy.d.ts",
      "import": "./dist/runtime/javy.js"
    }
  },
  "bin": {
    "zip-js": "./dist/build/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "NOTICE",
    "README.md",
    "HANZO_CHANGES.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test --import tsx src/handler.test.ts src/runtime/goja.test.ts src/runtime/javy.test.ts src/build/cli.test.ts",
    "examples": "node scripts/build-examples.mjs",
    "verify": "node scripts/verify-examples.mjs",
    "clean": "rm -rf dist examples/*/dist examples/*/*.js"
  },
  "dependencies": {
    "commander": "14.0.3",
    "esbuild": "0.28.0"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "tsx": "4.22.2",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "hanzo",
    "zip",
    "extensions",
    "goja",
    "wasm",
    "hip-0105"
  ]
}
